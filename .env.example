# ------------------------------------------------------------------
# Server-side (Next.js API routes)
# ------------------------------------------------------------------
# Used by /api/trigger-scraper and /api/scraper-progress
GH_TOKEN="your_github_token_here"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# Auto Website Builder (Cursor Cloud Agent + GitHub + Vercel)
CURSOR_API_KEY="your_cursor_api_key_here"
WEBSITE_BUILDER_REPO="owner/repo"
# Optional: for verifying Cursor webhook (POST /api/webhooks/cursor-agent)
# CURSOR_WEBHOOK_SECRET="your_webhook_secret"

# Vercel: clean preview URLs ({business-slug}-{id}.vercel.app)
VERCEL_TOKEN="your_vercel_token_here"
VERCEL_PROJECT_ID="prj_xxxx"
# Optional: if using a team
# VERCEL_TEAM_ID="team_xxxx"

# ------------------------------------------------------------------
# Client-side (browser) - for live results table
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
